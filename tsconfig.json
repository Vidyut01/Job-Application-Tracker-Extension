{
  "compilerOptions": {
    "target": "ES6",
    "module": "node16",
    "jsx": "react-jsx",
    "strict": true,
    "moduleResolution": "node16",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["chrome"],
  },
  "include": ["src"]
}
